# ===== LLM API Keys =====
# Premium model (orchestrator — planning, world spec, QC, synthesis only)
PREMIUM_MODEL=gpt-4o
PREMIUM_API_KEY=sk-...
PREMIUM_BASE_URL=https://api.openai.com/v1

# Cheap model (narrative worker — all per-agent and per-round generation)
CHEAP_MODEL=gpt-4o-mini
CHEAP_API_KEY=sk-...
CHEAP_BASE_URL=https://api.openai.com/v1

# ===== Datastores =====
POSTGRES_URL=postgresql://wc2026:wc2026_dev@localhost:5432/wc2026
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=wc2026_dev
REDIS_URL=redis://localhost:6379

# ===== Service URLs =====
OUTCOME_ENGINE_URL=http://localhost:8001
NARRATIVE_WORKER_URL=http://localhost:8002

# ===== Live results fetcher =====
# Source of live WC2026 results. Two options:
#   WC_RESULTS_SOURCE=fifa   -> pull from FIFA's API (api.fifa.com, unofficial)
#   WC_RESULTS_URL=<url>     -> fetch a JSON feed already in our shape
# See services/orchestrator/results_refresh.py for the payload shape. If neither
# is set, only the seeded snapshot is used (POST /admin/refresh can still accept
# a JSON body of scores by hand).
WC_RESULTS_SOURCE=
WC_RESULTS_URL=
# Optional FIFA adapter overrides (defaults target WC2026):
# FIFA_COMPETITION_ID=17
# FIFA_SEASON_ID=285023

# Shared secret guarding POST /admin/refresh. Set to a long random string to
# enable the endpoint; leave blank to disable it entirely (returns 503).
ADMIN_TOKEN=

# (legacy compose scheduler) seconds between refreshes (default 86400 = daily).
WC_REFRESH_INTERVAL=86400

# ===== Production guardrails =====
# Comma-separated allowed origins for CORS (default: local dev)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Maximum concurrent background simulation jobs
MAX_CONCURRENT_SIMS=5
